rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------
    // Helper Functions
    // -------------------

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Fetch user data (Costs 1 read)
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    // -------------------
    // Users Collection
    // -------------------
    match /users/{userId} {
      // Public profile read allowed (for brand details)
      allow read: if true;
      
      // Users can create/update only their own profile
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Update: Prevent role changes, ensure ownership, and allowlist specific fields
      allow update: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.data.role == resource.data.role // Role is immutable
                   && request.resource.data.keys().hasOnly([
                     "brandName", 
                     "description", 
                     "website", 
                     "logoUrl", 
                     "industry", 
                     "displayName", 
                     "updatedAt", 
                     "photoURL", 
                     "role",
                     "bio",
                     "profilePhotoURL",
                     "instagramLink",
                     "followerCount",
                     "ugcPortfolioLink",
                     "niches"
                   ]); 
      
      allow delete: if false; 
    }
    
    // -------------------
    // Campaigns Collection
    // -------------------
    match /campaigns/{campaignId} {
      // Public can read Active. Brand Owner can read everything (Drafts)
      allow read: if resource.data.status == "Active" 
                  || (request.auth != null && resource.data.brandId == request.auth.uid);
      
      // Create: Brand only, must own the campaign
      allow create: if hasRole('brand') 
                   && request.resource.data.brandId == request.auth.uid
                   && request.resource.data.status == "Active" 
                   && request.resource.data.createdAt != null;
      
      // Update: Brand owner only, cannot change brandId
      allow update: if hasRole('brand') 
                   && resource.data.brandId == request.auth.uid
                   && request.resource.data.brandId == resource.data.brandId;
                   
      // Delete: Brand owner only
      allow delete: if hasRole('brand') 
                   && resource.data.brandId == request.auth.uid;
    }

    // -------------------
    // Applications Collection
    // -------------------
    match /applications/{applicationId} {
      // Create: Only creators, must assign themselves as creatorId
      allow create: if isAuthenticated() 
                    && getUserData().role == "creator"
                    && request.resource.data.creatorId == request.auth.uid;

      // Read: Only the Brand who owns the campaign this application is for
      allow read: if isAuthenticated()
                  && get(/databases/$(database)/documents/campaigns/$(resource.data.campaignId)).data.brandId == request.auth.uid;
                  
      // No updates or deletes allowed from client
      allow update: if false;
      allow delete: if false;
    }
  }
}
